# ─────────────────────────────────────────────────────────────
# Swap — environment variables
# Copy this file to .env (root) and apps/web/.env.local, then fill in.
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe for the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the web app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TODO (Phase 2+): payment provider keys for premium services
# (account verification, item verification, featured ads, extra images).
# Do NOT implement payment now.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
