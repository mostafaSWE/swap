# ─────────────────────────────────────────────────────────────
# Swap — environment variables
# Copy to .env (root, used by the API + scripts) and apps/web/.env.local (web).
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Public app + API URLs ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL of the NestJS backend API. When set, the web/mobile apps route
# mutations + sensitive workflows through it. Leave EMPTY to fall back to direct
# Supabase (keeps the app runnable without the backend in local dev).
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Supabase (shared by web, API, mobile) ──
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key (safe for the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY (the NestJS API). Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# (Optional) Supabase JWT secret — only if you verify tokens locally instead of
# via the Auth API. The backend verifies tokens through Supabase by default.
SUPABASE_JWT_SECRET=

# ── Backend API ──
API_PORT=4000
NODE_ENV=development
# (Optional) Direct Postgres connection string, e.g. for future migrations tooling.
DATABASE_URL=

# ── Mobile (Expo) — optional, mirrors the public values above ──
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# TODO (Phase 2+): payment provider keys for premium services
# (account/item verification, featured ads, extra images). Do NOT implement now.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
