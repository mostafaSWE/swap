# ─────────────────────────────────────────────────────────────
# JustSwap — environment variables
# Copy to .env (root, used by the API + scripts) and apps/web/.env.local (web).
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Public app + API URLs ──
# Canonical public origin of the web app (no trailing slash). REQUIRED in
# production — on Vercel set it in Project Settings → Environment Variables for
# every environment. It drives metadataBase (canonical + OpenGraph URLs),
# robots.txt and sitemap.xml; if unset in prod the app falls back to
# http://localhost:3000 and ships localhost URLs to crawlers (logs a warning).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL of the NestJS backend API. When set, the web/mobile apps route
# mutations + sensitive workflows through it. Leave EMPTY to fall back to direct
# Supabase (keeps the app runnable without the backend in local dev).
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# The app is DATABASE-FIRST. Set to `true` ONLY for local development without a
# database — it makes read pages render a small built-in demo dataset. Keep
# `false` (or unset) in any real/connected environment.
NEXT_PUBLIC_USE_DEMO_DATA=false

# ── Supabase (shared by web, API, mobile) ──
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key (safe for the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY (the NestJS API). Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# (Optional) Supabase JWT secret — only if you verify tokens locally instead of
# via the Auth API. The backend verifies tokens through Supabase by default.
SUPABASE_JWT_SECRET=

# ── Backend API ──
API_PORT=4000
NODE_ENV=development
# (Optional) Comma-separated CORS allowlist for the API. Defaults to
# NEXT_PUBLIC_APP_URL (or http://localhost:3000) when unset/blank. The API no
# longer reflects arbitrary origins — list every web origin that calls it from a browser.
CORS_ORIGINS=http://localhost:3000
# (Optional) Set ONLY when the API runs behind a reverse proxy (nginx/ALB/Cloudflare)
# so the rate limiter sees the real client IP from X-Forwarded-For. Value is a hop
# count ("1"), "true", or a trusted subnet. Leave UNSET for direct connections —
# trusting XFF from an untrusted network lets clients spoof their IP past rate limits.
TRUST_PROXY=
# (Optional) Direct Postgres connection string, e.g. for future migrations tooling.
DATABASE_URL=

# ── Moderation ──
# Pending 'listing' reports that auto soft-hide a listing (status → hidden),
# spec §3.8. NOTE: enforcement lives in the DB trigger `auto_hide_reported_listing`
# (migration 0009) so it covers every report write path — this value documents the
# default; retune by editing the `threshold` constant in that trigger to match.
REPORT_AUTO_HIDE_THRESHOLD=5

# ── Mobile (Expo) — optional, mirrors the public values above ──
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# ── Email (Resend) — auth emails: confirm signup + reset password ──
# These power the `supabase/functions/send-email` Edge Function (the Supabase
# "Send Email" Auth Hook). They are NOT read by the web/API apps — set them as
# EDGE FUNCTION SECRETS, not here:
#   supabase secrets set RESEND_API_KEY=... SEND_EMAIL_HOOK_SECRET=... \
#                        RESEND_FROM="JustSwap <noreply@yourdomain>" \
#                        PUBLIC_APP_URL=https://yourapp.com
# • RESEND_API_KEY        — from resend.com → API Keys (re_...).
# • SEND_EMAIL_HOOK_SECRET— generated by Supabase when you enable the Send Email
#                           Hook (Dashboard → Auth → Hooks); format "v1,whsec_...".
# • RESEND_FROM           — a verified-domain sender, e.g. "JustSwap <noreply@swap.app>".
# • PUBLIC_APP_URL        — same value as NEXT_PUBLIC_APP_URL above (link base).
# Also add NEXT_PUBLIC_APP_URL + "<app>/**" to Supabase → Auth → URL Configuration
# → Redirect URLs so the reset/confirm links are allowed.

# TODO (Phase 2+): payment provider keys for premium services
# (account/item verification, featured ads, extra images). Do NOT implement now.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
