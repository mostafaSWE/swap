{
  "name": "@swap/api-server",
  "version": "0.1.0",
  "private": true,
  "description": "JustSwap backend API (NestJS) - business logic layer consumed by web + mobile.",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint not configured for api-server)\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^8.0.1",
    "@nestjs/throttler": "^6.3.0",
    "@supabase/supabase-js": "^2.107.0",
    "helmet": "^8.0.0",
    "@swap/config": "workspace:*",
    "@swap/types": "workspace:*",
    "@swap/validation": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
