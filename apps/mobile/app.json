{
  "expo": {
    "name": "JustSwap",
    "slug": "justswap",
    "scheme": "justswap",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.justswap.app",
      "infoPlist": {
        "CFBundleLocalizations": ["ar", "en"],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "package": "me.justswap.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0A0E1A",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      "expo-localization",
      "./plugins/withAndroidRtlEarlySet"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}
