# apps/mobile — Expo public env (committed template; copy to apps/mobile/.env).
# EXPO_PUBLIC_* are inlined into the JS bundle at build time. Use the PUBLIC
# "publishable" / anon key only — never the service-role / secret key.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend REST base URL. On device/emulator, localhost won't reach your machine:
#   Android emulator  → http://10.0.2.2:4000/api/v1
#   Real device (LAN) → http://<your-machine-LAN-IP>:4000/api/v1
#   Deployed API      → https://<your-api-host>/api/v1
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api/v1
